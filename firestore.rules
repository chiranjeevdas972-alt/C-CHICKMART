rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net - Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }
    
    function isVerifiedEmailUser() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isGoogleUser() {
      return isSignedIn() && request.auth.token.firebase.sign_in_provider == "google.com";
    }

    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'user') == 'admin';
    }

    // 1. User profiles
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string &&
             data.email.size() < 256;
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId && isValidUser(incoming());
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    // 2. OTP Management - Allow unverified users to write their own OTP
    function isValidOTP(data) {
      // Must match UI/Service expectations
      return data.keys().hasAll(['otp', 'email', 'createdAt', 'expiresAt', 'verified', 'attempts']) &&
             data.otp is string && data.otp.size() == 6 &&
             data.email is string &&
             data.verified is bool;
    }

    match /emailOtps/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;
      allow write: if isSignedIn() && request.auth.uid == uid;
    }

    // 3. Other Collections (Production Safe)
    match /farms/{farmId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (isGoogleUser() || isVerifiedEmailUser() || isAdmin());
    }

    match /shops/{shopId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (isGoogleUser() || isVerifiedEmailUser() || isAdmin());
    }

    match /inventory/{itemId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (isGoogleUser() || isVerifiedEmailUser() || isAdmin());
    }

    match /farmLogs/{logId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (isGoogleUser() || isVerifiedEmailUser() || isAdmin());
    }
    
    match /notifications/{notifId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isSignedIn();
    }

    match /activity/{activityId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
    
    match /sales/{saleId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (isGoogleUser() || isVerifiedEmailUser() || isAdmin());
    }
    
    match /customers/{customerId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (isGoogleUser() || isVerifiedEmailUser() || isAdmin());
    }
  }
}
