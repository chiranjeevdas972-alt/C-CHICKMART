rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /otp_verification/{docId} {
      allow read, write: if true;
    }

    match /users/{userId} {
      allow read, write: if request.auth != null;
    }

    // Default catch-all for development if needed, but keeping it secure
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
